# Environment Variables — Nudge
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# ─── Landing (optional — Wave 1 distribution) ────────────────────────
# When set, shown under trust stat on /. When empty, row is hidden per screen spec.
# VITE_LANDING_TASKS_COMPLETED_LABEL=1.2M tasks completed across Nudge users

# ─── Supabase (required) ───────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=              # Server-only — Edge Functions only, never in frontend

# ─── LLM (northstar §10 — Anthropic; RAD default path may use OpenRouter in Edge Functions)
ANTHROPIC_API_KEY=                      # Server-only — if calling Claude directly from Edge Functions
OPENROUTER_API_KEY=                     # Server-only — optional RAD pattern; use if routing LLM via OpenRouter

# ─── Google OAuth + APIs (northstar §10) ───────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Stripe (northstar §11 — Phase 1 PWA) ───────────────────────────
STRIPE_SECRET_KEY=                      # Server-only
STRIPE_WEBHOOK_SECRET=                  # Server-only
VITE_STRIPE_PUBLISHABLE_KEY=            # Client-safe (if using Stripe.js / Elements)

# ─── Web Push (northstar §10) ─────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Transactional email (northstar §10 — e.g. Resend) ───────────────
RESEND_API_KEY=                         # Server-only

# Phase 2 / optional (set when native or additional providers ship)
# APPLE_SERVICE_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=
# DEEPGRAM_API_KEY=
# REVENUECAT_API_KEY=
# REVENUECAT_WEBHOOK_SECRET=
# FCM_SERVER_KEY=
# APNS_KEY_ID=
# APNS_TEAM_ID=
