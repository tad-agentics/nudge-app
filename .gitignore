# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# vite / react-router
/dist/
/.react-router/
/build/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo

# Dev Workspace
.local/

# RAD — Figma Make import staging dir (temporary, deleted after porting)
src/make-import/

# RAD — agent-workspace operational files (project-specific, never commit)
agent-workspace/ACTIVE_CONTEXT.md
agent-workspace/memory/*.md
agent-workspace/temp/*
!agent-workspace/temp/.gitkeep
agent-workspace/scripts/*
!agent-workspace/scripts/.gitkeep

# RAD — local sync target when using vendored rad-rr7-template
rad-rr7-template/.sync-target

# RAD — MCP config contains credentials
.cursor/mcp.json
