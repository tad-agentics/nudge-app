# Environment Variables — [App Name]
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# ─── Supabase (required) ───────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=              # Server-only — Edge Functions only, never in frontend

# ─── Resend (if product sends transactional email) ─────────────────────
# RESEND_API_KEY=                        # Server-only — Edge Functions only

# ─── Payment provider (variable names depend on provider) ──────────────
# See northstar §11 for the exact provider and required variables.
# Example for Stripe:
#   STRIPE_SECRET_KEY=                   # Server-only — Edge Functions only
#   VITE_STRIPE_PUBLISHABLE_KEY=         # Client-safe
#   STRIPE_WEBHOOK_SECRET=               # Server-only — Edge Functions only
# Example for PayOS:
#   PAYOS_CLIENT_ID=                     # Server-only — Edge Functions only
#   PAYOS_API_KEY=                       # Server-only — Edge Functions only
#   PAYOS_CHECKSUM_KEY=                  # Server-only — Edge Functions only

# ─── LLM via OpenRouter (required — all RAD apps use LLM) ────────────
OPENROUTER_API_KEY=                      # Server-only — Edge Functions only. Get from https://openrouter.ai/keys
# Default model: anthropic/claude-sonnet-4 (change per app in Edge Function config)

# Add project-specific variables below this line
# ---
